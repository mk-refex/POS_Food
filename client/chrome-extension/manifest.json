{
  "manifest_version": 3,
  "name": "Silent Print Extension",
  "version": "1.0",
  "description": "Enables silent printing for POS Food System",
  "permissions": [
    "activeTab",
    "printing"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
